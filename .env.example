# ═══════════════════════════════════════
# AutoControl — Variables de Entorno
# ═══════════════════════════════════════

# ── Base de Datos ──
DATABASE_URL=postgresql://autocontrol:your_secure_password@localhost:5432/autocontrol_db

# ── JWT Auth ──
JWT_SECRET=cambia-esto-por-un-string-seguro-de-64-caracteres-minimo
JWT_REFRESH_SECRET=otro-string-seguro-diferente-para-refresh-tokens
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ──
NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ── Uploads ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Admin Seed ──
ADMIN_EMAIL=admin@autocontrol.co
ADMIN_PASSWORD=cambia-esta-password
ADMIN_PIN=1234

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
