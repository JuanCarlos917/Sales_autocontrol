# ═══════════════════════════════════════
# AutoControl — Variables de Entorno
# ═══════════════════════════════════════

# ── Base de Datos ──
DATABASE_URL=postgresql://autocontrol:your_secure_password@localhost:5432/autocontrol_db

# ── Docker Compose ──
# Solo se usan cuando despliegas con docker-compose (este archivo se copia a .env en la raíz).
# DB_PASSWORD construye el DATABASE_URL del contenedor y la contraseña de Postgres.
# VITE_API_URL es la ruta que usa el navegador para la API: déjala como /api (Caddy la enruta).
DB_PASSWORD=cambia-esta-clave-de-base-de-datos
VITE_API_URL=/api

# ── TLS / Caddy (HTTPS automático) ──
# Caddy emite y renueva el certificado solo. El DNS de DOMAIN debe apuntar al
# servidor ANTES de levantar el stack, o la emisión del certificado fallará.
DOMAIN=autocontrol.co
ACME_EMAIL=tu-correo@ejemplo.com

# ── JWT Auth ──
JWT_SECRET=cambia-esto-por-un-string-seguro-de-64-caracteres-minimo
JWT_REFRESH_SECRET=otro-string-seguro-diferente-para-refresh-tokens
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ──
NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ── Uploads ──
# Sin S3_BUCKET se usa disco local (UPLOAD_DIR). Con S3_BUCKET, los archivos van a S3
# (persistente) y se sirven con URLs prefirmadas. El disco del contenedor es efímero,
# así que en producción usa S3 (recomendado) o un volumen persistente.
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
# Para AWS S3: define los tres. Usa un usuario IAM con permiso solo a este bucket
# (PutObject/GetObject/DeleteObject). El bucket debe ser privado.
# S3_BUCKET=autocontrol-uploads
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Admin Seed ──
# En producción el servidor NO arranca si estos valores faltan o son débiles:
#   JWT_SECRET / JWT_REFRESH_SECRET: mínimo 32 caracteres y distintos entre sí
#   ADMIN_PASSWORD: mínimo 8 caracteres · ADMIN_PIN: mínimo 6 dígitos
ADMIN_EMAIL=admin@autocontrol.co
ADMIN_PASSWORD=cambia-esta-clave-min-8
ADMIN_PIN=654321

# ── Rate Limiting ──
# Límite por IP del cliente real (el backend confía en 1 salto de proxy: Caddy).
# 300 req / 15 min por IP es holgado para una SPA y sigue protegiendo de abuso.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ── Observabilidad (opcional) ──
# Si defines SENTRY_DSN, los errores de servidor (5xx) se envían a Sentry.
# Sin esta variable, el monitoreo queda desactivado (la app funciona igual).
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# ── IA: extracción de documentos (opcional) ──
# Si defines ANTHROPIC_API_KEY, al subir una "Tarjeta de propiedad" la API extrae
# placa/marca/modelo/año/color (Claude vision) y los sugiere para aplicar al
# vehículo. Sin esta variable, el upload funciona igual pero sin sugerencias.
# Consíguela en https://console.anthropic.com → Settings → API Keys.
# ANTHROPIC_API_KEY=
