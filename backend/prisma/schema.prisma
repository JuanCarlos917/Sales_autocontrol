// ═══════════════════════════════════════════════════════════════
// AutoControl — Database Schema (Prisma)
// Fuente de verdad para todas las tablas y relaciones
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════
// USUARIOS Y AUTENTICACIÓN
// ══════════════════════════════════════════════════════════════

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  pin       String?
  name      String?
  role      Role      @default(SUPERVISOR)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vehicles          Vehicle[]
  refreshTokens     RefreshToken[]
  expenseAuditLogs  ExpenseAuditLog[]
  vehicleAuditLogs  VehicleAuditLog[]
  treasuryAuditLogs TreasuryAuditLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

enum Role {
  ADMIN
  SUPERVISOR
  VIEWER
}

// ══════════════════════════════════════════════════════════════
// VEHÍCULOS
// ══════════════════════════════════════════════════════════════

model Vehicle {
  id    String       @id @default(cuid())
  plate String
  brand String?
  model String?
  year  Int?
  color String?
  km    Int?
  stage VehicleStage @default(NEGOCIANDO)

  negotiatedValue        Decimal? @db.Decimal(15, 2)
  purchasePrice          Decimal? @db.Decimal(15, 2)
  listedPrice            Decimal? @db.Decimal(15, 2)
  salePrice              Decimal? @db.Decimal(15, 2)
  participation          Decimal  @default(1.0) @db.Decimal(5, 4)
  partnerContribution    Decimal? @db.Decimal(15, 2)
  partnerAssumesExpenses Boolean  @default(true)

  purchaseDate DateTime?
  saleDate     DateTime?

  receivedVehicle      Boolean  @default(false)
  receivedVehiclePlate String?
  receivedVehicleValue Decimal? @db.Decimal(15, 2)

  // true cuando este vehículo nació de un cruce (parte de pago de otra venta):
  // arranca en NEGOCIANDO con negotiatedValue fijo = valor del cruce (inmutable).
  fromTradeIn Boolean @default(false)

  // Self-relation: cuando fromTradeIn=true, sourceVehicleId apunta a la venta que
  // generó este cruce. tradeInsReceived es la lista reverse de cruces que un
  // vehículo VENDIDO recibió como parte de pago.
  sourceVehicleId    String?
  sourceVehicle      Vehicle?  @relation("VehicleTradeInSource", fields: [sourceVehicleId], references: [id], onDelete: SetNull)
  tradeInsReceived   Vehicle[] @relation("VehicleTradeInSource")

  publishedPortals String[] @default([])

  // Terceros asociados al vehículo
  supplierId String?
  supplier   ThirdParty? @relation("VehicleSupplier", fields: [supplierId], references: [id])
  partnerId  String?
  partner    ThirdParty? @relation("VehiclePartner", fields: [partnerId], references: [id])
  buyerId    String?
  buyer      ThirdParty? @relation("VehicleBuyer", fields: [buyerId], references: [id])

  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses         Expense[]
  documents        Document[]
  payables         Payable[]
  transactions     Transaction[]
  auditLogs        VehicleAuditLog[]
  saleParticipants SaleParticipant[]

  @@index([userId, stage])
  @@index([plate])
  @@index([supplierId])
  @@index([partnerId])
  @@index([buyerId])
  @@index([sourceVehicleId])
  @@map("vehicles")
}

enum VehicleStage {
  NEGOCIANDO
  COMPRADO
  ALISTAMIENTO
  PUBLICADO
  DISPONIBLE
  VENDIDO
}

// ══════════════════════════════════════════════════════════════
// GASTOS
// ══════════════════════════════════════════════════════════════

model Expense {
  id          String          @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account         @relation(fields: [accountId], references: [id])
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(15, 2)
  description String?
  notes       String?
  date        DateTime?
  paid        Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String?
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?

  payable      Payable?
  transactions Transaction[]
  auditLogs    ExpenseAuditLog[]

  @@index([vehicleId])
  @@index([category])
  @@index([accountId])
  @@index([deletedAt])
  @@map("expenses")
}

enum ExpenseCategory {
  MECANICA
  ESTETICA
  IMPUESTOS
  TRAMITE
  PARQUEADERO
  PUBLICIDAD
  COMBUSTIBLE
  OTRO
}

// ══════════════════════════════════════════════════════════════
// DOCUMENTOS
// ══════════════════════════════════════════════════════════════

model Document {
  id            String       @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type          DocumentType
  filename      String
  filepath      String
  mimetype      String?
  size          Int?
  notes         String?
  // Datos extraídos por IA al subir el documento (p. ej. campos de la tarjeta de
  // propiedad). Null si la extracción no se ejecutó o no produjo resultados.
  extractedData Json?
  createdAt     DateTime     @default(now())

  @@index([vehicleId])
  @@map("documents")
}

enum DocumentType {
  TARJETA_PROPIEDAD
  SOAT
  TECNOMECANICA
  PERITAJE
  CERTIFICADO_TRADICION
  CONTRATO
  FOTO_VEHICULO
  OTRO
}

// ══════════════════════════════════════════════════════════════
// CONFIGURACIÓN
// ══════════════════════════════════════════════════════════════

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - CUENTAS
// ══════════════════════════════════════════════════════════════

model Account {
  id             String      @id @default(cuid())
  name           String
  type           AccountType
  bank           String?
  accountNumber  String?
  initialBalance Decimal     @default(0) @db.Decimal(15, 2)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transactions  Transaction[]
  transfersFrom Transfer[]    @relation("TransferFrom")
  transfersTo   Transfer[]    @relation("TransferTo")
  cashCounts    CashCount[]
  expenses      Expense[]
  loans         Loan[]        @relation("LoanOriginAccount")
  loanPayments  LoanPayment[] @relation("LoanPaymentAccount")
  debtPayments  DebtPayment[] @relation("DebtPaymentAccount")

  @@map("accounts")
}

enum AccountType {
  CASH
  BANK
  BUDGET
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - TERCEROS
// ══════════════════════════════════════════════════════════════

model ThirdParty {
  id        String         @id @default(cuid())
  name      String
  type      ThirdPartyType
  document  String?
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  transactions       Transaction[]
  payables           Payable[]
  vehiclesAsSupplier Vehicle[]     @relation("VehicleSupplier")
  vehiclesAsPartner  Vehicle[]     @relation("VehiclePartner")
  vehiclesAsBuyer    Vehicle[]     @relation("VehicleBuyer")
  loansAsBorrower    Loan[]        @relation("LoanBorrower")
  saleParticipants   SaleParticipant[]

  @@map("third_parties")
}

enum ThirdPartyType {
  CLIENT
  SUPPLIER
  PARTNER
  EMPLOYEE
  BOTH
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - TRANSACCIONES
// ══════════════════════════════════════════════════════════════

model Transaction {
  id           String              @id @default(cuid())
  accountId    String
  account      Account             @relation(fields: [accountId], references: [id])
  type         TransactionType
  category     TransactionCategory
  amount       Decimal             @db.Decimal(15, 2)
  description  String?
  reference    String?
  date         DateTime            @default(now())
  vehicleId    String?
  vehicle      Vehicle?            @relation(fields: [vehicleId], references: [id])
  thirdPartyId String?
  thirdParty   ThirdParty?         @relation(fields: [thirdPartyId], references: [id])
  transferId   String?
  transfer     Transfer?           @relation(fields: [transferId], references: [id])
  expenseId    String?
  expense      Expense?            @relation(fields: [expenseId], references: [id])
  // Self-relation: cuando una Transaction es un EXPENSE_ADJUSTMENT o
  // EXPENSE_REVERSAL, apunta a la Transaction original que ajusta/reversa.
  // Permite navegar lineage sin parsear descripciones.
  reversesTransactionId String?
  reversesTransaction   Transaction?  @relation("TransactionReverses", fields: [reversesTransactionId], references: [id], onDelete: SetNull)
  reversedBy            Transaction[] @relation("TransactionReverses")
  createdBy    String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  payablePayment PayablePayment?
  loanId         String?
  loan           Loan?           @relation(fields: [loanId], references: [id])
  loanPaymentId  String?
  loanPayment    LoanPayment?    @relation(fields: [loanPaymentId], references: [id])
  debtId        String?
  debt          Debt?        @relation(fields: [debtId], references: [id])
  debtPaymentId String?
  debtPayment   DebtPayment? @relation(fields: [debtPaymentId], references: [id])

  @@index([accountId])
  @@index([vehicleId])
  @@index([thirdPartyId])
  @@index([date])
  @@index([type, category])
  @@index([loanId])
  @@index([loanPaymentId])
  @@index([expenseId])
  @@index([reversesTransactionId])
  @@index([debtId])
  @@index([debtPaymentId])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER_IN
  TRANSFER_OUT
}

enum TransactionCategory {
  VEHICLE_PURCHASE
  VEHICLE_SALE
  VEHICLE_SALE_PARTIAL
  VEHICLE_EXPENSE
  FIXED_EXPENSE
  OPERATING_EXPENSE
  COMMISSION
  CAPITAL_CONTRIBUTION
  OTHER_INCOME
  OTHER_EXPENSE
  TRANSFER
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  LOAN_EXTRA_INCOME
  LOAN_INTEREST_INCOME
  DEBT_PAYMENT
  EXPENSE_ADJUSTMENT
  EXPENSE_REVERSAL
  MANUAL_REVERSAL
  LOAN_REVERSAL
  DEBT_REVERSAL
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - TRANSFERENCIAS
// ══════════════════════════════════════════════════════════════

model Transfer {
  id            String   @id @default(cuid())
  fromAccountId String
  fromAccount   Account  @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccountId   String
  toAccount     Account  @relation("TransferTo", fields: [toAccountId], references: [id])
  amount        Decimal  @db.Decimal(15, 2)
  description   String?
  date          DateTime @default(now())
  createdBy     String
  createdAt     DateTime @default(now())

  transactions Transaction[]

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([date])
  @@map("transfers")
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - ARQUEOS
// ══════════════════════════════════════════════════════════════

model CashCount {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id])
  expectedBalance Decimal  @db.Decimal(15, 2)
  countedBalance  Decimal  @db.Decimal(15, 2)
  difference      Decimal  @db.Decimal(15, 2)
  notes           String?
  voidedAt        DateTime?
  voidedBy        String?
  voidReason      String?
  date            DateTime @default(now())
  createdBy       String
  createdAt       DateTime @default(now())

  @@index([accountId])
  @@index([date])
  @@map("cash_counts")
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - CUENTAS POR COBRAR / PAGAR (CxC / CxP)
// ══════════════════════════════════════════════════════════════

model Payable {
  id           String        @id @default(cuid())
  type         PayableType
  status       PayableStatus @default(PENDING)
  totalAmount  Decimal       @db.Decimal(15, 2)
  paidAmount   Decimal       @default(0) @db.Decimal(15, 2)
  dueDate      DateTime?
  description  String?
  vehicleId    String?
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id])
  expenseId    String?       @unique
  expense      Expense?      @relation(fields: [expenseId], references: [id])
  thirdPartyId String?
  thirdParty   ThirdParty?   @relation(fields: [thirdPartyId], references: [id])
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  payments        PayablePayment[]
  saleParticipant SaleParticipant?

  @@index([vehicleId])
  @@index([thirdPartyId])
  @@index([type, status])
  @@index([dueDate])
  @@map("payables")
}

model SaleParticipant {
  id           String          @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  thirdPartyId String
  thirdParty   ThirdParty      @relation(fields: [thirdPartyId], references: [id])
  role         ParticipantRole
  sharePct     Decimal         @db.Decimal(5, 2)
  amount       Decimal         @db.Decimal(15, 2)
  payableId    String?         @unique
  payable      Payable?        @relation(fields: [payableId], references: [id])
  createdAt    DateTime        @default(now())

  @@index([vehicleId])
  @@index([thirdPartyId])
  @@map("sale_participants")
}

enum ParticipantRole {
  CAPTADOR
  CERRADOR
  OTHER
  INVESTOR
}

model PayablePayment {
  id            String      @id @default(cuid())
  payableId     String
  payable       Payable     @relation(fields: [payableId], references: [id], onDelete: Cascade)
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  amount        Decimal     @db.Decimal(15, 2)
  createdAt     DateTime    @default(now())

  @@index([payableId])
  @@map("payable_payments")
}

enum PayableType {
  RECEIVABLE
  PAYABLE
  COMMISSION
  PROFIT_SHARE
}

enum PayableStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - PRÉSTAMOS INTERNOS
// ══════════════════════════════════════════════════════════════

model Loan {
  id               String     @id @default(cuid())
  borrowerId       String
  originAccountId  String
  principalAmount  Decimal    @db.Decimal(15, 2)
  paidAmount       Decimal    @default(0) @db.Decimal(15, 2)
  extraReceived    Decimal    @default(0) @db.Decimal(15, 2)
  interestRate     Decimal    @default(0) @db.Decimal(5, 2)
  interestAmount   Decimal    @default(0) @db.Decimal(15, 2)
  interestReceived Decimal    @default(0) @db.Decimal(15, 2)
  status           LoanStatus @default(PENDING)
  description      String?
  disbursementDate DateTime   @default(now())
  notes            String?
  createdBy        String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  borrower      ThirdParty        @relation("LoanBorrower", fields: [borrowerId], references: [id])
  originAccount Account           @relation("LoanOriginAccount", fields: [originAccountId], references: [id])
  installments  LoanInstallment[]
  payments      LoanPayment[]
  transactions  Transaction[]

  @@index([borrowerId])
  @@index([status])
  @@map("loans")
}

model LoanInstallment {
  id            String            @id @default(cuid())
  loanId        String
  sequence      Int
  dueDate       DateTime
  plannedAmount Decimal           @db.Decimal(15, 2)
  paidAmount    Decimal           @default(0) @db.Decimal(15, 2)
  status        InstallmentStatus @default(PENDING)

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, sequence])
  @@index([dueDate])
  @@map("loan_installments")
}

model LoanPayment {
  id              String   @id @default(cuid())
  loanId          String
  accountId       String
  principalAmount Decimal  @db.Decimal(15, 2)
  extraAmount     Decimal  @default(0) @db.Decimal(15, 2)
  capitalPortion  Decimal  @default(0) @db.Decimal(15, 2)
  interestPortion Decimal  @default(0) @db.Decimal(15, 2)
  date            DateTime @default(now())
  notes           String?
  reversedAt      DateTime?
  reversedBy      String?
  reverseReason   String?
  createdBy       String
  createdAt       DateTime @default(now())

  loan         Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  account      Account       @relation("LoanPaymentAccount", fields: [accountId], references: [id])
  transactions Transaction[]

  @@index([loanId])
  @@map("loan_payments")
}

enum LoanStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

model Debt {
  id               String     @id @default(cuid())
  name             String
  lender           String?
  assetDescription String?
  totalAmount      Decimal    @db.Decimal(15, 2)
  paidAmount       Decimal    @default(0) @db.Decimal(15, 2)
  status           DebtStatus @default(PENDING)
  startDate        DateTime   @default(now())
  notes            String?
  createdBy        String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  installments DebtInstallment[]
  payments     DebtPayment[]
  transactions Transaction[]

  @@index([status])
  @@map("debts")
}

model DebtInstallment {
  id            String            @id @default(cuid())
  debtId        String
  sequence      Int
  dueDate       DateTime
  plannedAmount Decimal           @db.Decimal(15, 2)
  paidAmount    Decimal           @default(0) @db.Decimal(15, 2)
  status        InstallmentStatus @default(PENDING)

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@unique([debtId, sequence])
  @@index([dueDate])
  @@map("debt_installments")
}

model DebtPayment {
  id        String   @id @default(cuid())
  debtId    String
  accountId String
  amount    Decimal  @db.Decimal(15, 2)
  date          DateTime  @default(now())
  notes         String?
  reversedAt    DateTime?
  reversedBy    String?
  reverseReason String?
  reconciled    Boolean   @default(false)
  createdBy     String
  createdAt     DateTime  @default(now())

  debt         Debt          @relation(fields: [debtId], references: [id], onDelete: Cascade)
  account      Account       @relation("DebtPaymentAccount", fields: [accountId], references: [id])
  transactions Transaction[]

  @@index([debtId])
  @@map("debt_payments")
}

enum DebtStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
}

// ══════════════════════════════════════════════════════════════
// AUDITORÍA DE GASTOS
// ══════════════════════════════════════════════════════════════

model ExpenseAuditLog {
  id        String             @id @default(cuid())
  expenseId String
  expense   Expense            @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  action    ExpenseAuditAction
  before    Json?
  after     Json?
  reason    String?
  createdAt DateTime           @default(now())

  @@index([expenseId])
  @@index([userId])
  @@index([createdAt])
  @@map("expense_audit_logs")
}

enum ExpenseAuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
}

// ══════════════════════════════════════════════════════════════
// AUDITORÍA DE VEHÍCULOS
// ══════════════════════════════════════════════════════════════

model VehicleAuditLog {
  id        String             @id @default(cuid())
  vehicleId String
  vehicle   Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  action    VehicleAuditAction
  before    Json?
  after     Json?
  reason    String?
  createdAt DateTime           @default(now())

  @@index([vehicleId])
  @@index([userId])
  @@index([createdAt])
  @@map("vehicle_audit_logs")
}

enum VehicleAuditAction {
  CREATE
  UPDATE
  STAGE_CHANGE
  DELETE
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - AUDIT LOG POLIMÓRFICO
// ══════════════════════════════════════════════════════════════

model TreasuryAuditLog {
  id         String              @id @default(cuid())
  entityType TreasuryAuditEntity
  entityId   String
  userId     String
  user       User                @relation(fields: [userId], references: [id])
  action     TreasuryAuditAction
  before     Json?
  after      Json?
  reason     String?
  createdAt  DateTime            @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("treasury_audit_logs")
}

enum TreasuryAuditEntity {
  TRANSACTION
  TRANSFER
  ACCOUNT
  THIRD_PARTY
  PAYABLE
  PAYABLE_PAYMENT
  DEBT
  LOAN
  LOAN_PAYMENT
  DEBT_PAYMENT
  CASH_COUNT
}

enum TreasuryAuditAction {
  CREATE
  UPDATE
  DELETE
  CANCEL
  PAYMENT
  REVERSE
}
