generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model accounts {
  id                                          String         @id
  name                                        String
  type                                        AccountType
  bank                                        String?
  accountNumber                               String?
  initialBalance                              Decimal        @default(0) @db.Decimal(15, 2)
  isActive                                    Boolean        @default(true)
  createdAt                                   DateTime       @default(now())
  updatedAt                                   DateTime
  cash_counts                                 cash_counts[]
  transactions                                transactions[]
  transfers_transfers_fromAccountIdToaccounts transfers[]    @relation("transfers_fromAccountIdToaccounts")
  transfers_transfers_toAccountIdToaccounts   transfers[]    @relation("transfers_toAccountIdToaccounts")
}

model cash_counts {
  id              String   @id
  accountId       String
  expectedBalance Decimal  @db.Decimal(15, 2)
  countedBalance  Decimal  @db.Decimal(15, 2)
  difference      Decimal  @db.Decimal(15, 2)
  notes           String?
  date            DateTime @default(now())
  createdBy       String
  createdAt       DateTime @default(now())
  accounts        accounts @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([date])
}

model documents {
  id        String       @id
  vehicleId String
  type      DocumentType
  filename  String
  filepath  String
  mimetype  String?
  size      Int?
  notes     String?
  createdAt DateTime     @default(now())
  vehicles  vehicles     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model expenses {
  id          String          @id
  vehicleId   String
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(15, 2)
  description String?
  notes       String?
  date        DateTime?
  paid        Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime
  vehicles    vehicles        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  payables    payables?

  @@index([category])
  @@index([vehicleId])
}

model payable_payments {
  id            String       @id
  payableId     String
  transactionId String       @unique
  amount        Decimal      @db.Decimal(15, 2)
  createdAt     DateTime     @default(now())
  payables      payables     @relation(fields: [payableId], references: [id], onDelete: Cascade)
  transactions  transactions @relation(fields: [transactionId], references: [id])

  @@index([payableId])
}

model payables {
  id               String             @id
  type             PayableType
  status           PayableStatus      @default(PENDING)
  totalAmount      Decimal            @db.Decimal(15, 2)
  paidAmount       Decimal            @default(0) @db.Decimal(15, 2)
  dueDate          DateTime?
  description      String?
  vehicleId        String?
  expenseId        String?            @unique
  thirdPartyId     String?
  createdBy        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  payable_payments payable_payments[]
  expenses         expenses?          @relation(fields: [expenseId], references: [id])
  third_parties    third_parties?     @relation(fields: [thirdPartyId], references: [id])
  vehicles         vehicles?          @relation(fields: [vehicleId], references: [id])

  @@index([dueDate])
  @@index([thirdPartyId])
  @@index([type, status])
  @@index([vehicleId])
}

model refresh_tokens {
  id        String   @id
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model settings {
  id    String @id
  key   String @unique
  value String
}

model third_parties {
  id           String         @id
  name         String
  type         ThirdPartyType
  document     String?
  phone        String?
  email        String?
  notes        String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  payables     payables[]
  transactions transactions[]
}

model transactions {
  id               String              @id
  accountId        String
  type             TransactionType
  category         TransactionCategory
  amount           Decimal             @db.Decimal(15, 2)
  description      String?
  reference        String?
  date             DateTime            @default(now())
  vehicleId        String?
  thirdPartyId     String?
  transferId       String?
  expenseId        String?             @unique
  createdBy        String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime
  payable_payments payable_payments?
  accounts         accounts            @relation(fields: [accountId], references: [id])
  third_parties    third_parties?      @relation(fields: [thirdPartyId], references: [id])
  transfers        transfers?          @relation(fields: [transferId], references: [id])

  @@index([accountId])
  @@index([date])
  @@index([thirdPartyId])
  @@index([type, category])
  @@index([vehicleId])
}

model transfers {
  id                                         String         @id
  fromAccountId                              String
  toAccountId                                String
  amount                                     Decimal        @db.Decimal(15, 2)
  description                                String?
  date                                       DateTime       @default(now())
  createdBy                                  String
  createdAt                                  DateTime       @default(now())
  transactions                               transactions[]
  accounts_transfers_fromAccountIdToaccounts accounts       @relation("transfers_fromAccountIdToaccounts", fields: [fromAccountId], references: [id])
  accounts_transfers_toAccountIdToaccounts   accounts       @relation("transfers_toAccountIdToaccounts", fields: [toAccountId], references: [id])

  @@index([date])
  @@index([fromAccountId])
  @@index([toAccountId])
}

model users {
  id             String           @id
  email          String           @unique
  password       String
  pin            String?
  name           String?
  role           Role             @default(ADMIN)
  isActive       Boolean          @default(true)
  lastLogin      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  refresh_tokens refresh_tokens[]
  vehicles       vehicles[]
}

model vehicles {
  id                   String       @id
  plate                String
  brand                String?
  model                String?
  year                 Int?
  color                String?
  km                   Int?
  stage                VehicleStage @default(NEGOCIANDO)
  purchasePrice        Decimal?     @db.Decimal(15, 2)
  listedPrice          Decimal?     @db.Decimal(15, 2)
  salePrice            Decimal?     @db.Decimal(15, 2)
  participation        Decimal      @default(1.0) @db.Decimal(5, 4)
  purchaseDate         DateTime?
  saleDate             DateTime?
  receivedVehicle      Boolean      @default(false)
  receivedVehiclePlate String?
  receivedVehicleValue Decimal?     @db.Decimal(15, 2)
  publishedPortals     String[]     @default([])
  notes                String?
  userId               String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime
  documents            documents[]
  expenses             expenses[]
  payables             payables[]
  users                users        @relation(fields: [userId], references: [id])

  @@index([plate])
  @@index([userId, stage])
}

enum AccountType {
  CASH
  SAVINGS
}

enum DocumentType {
  TARJETA_PROPIEDAD
  SOAT
  TECNOMECANICA
  PERITAJE
  CERTIFICADO_TRADICION
  CONTRATO
  FOTO_VEHICULO
  OTRO
}

enum ExpenseCategory {
  MECANICA
  ESTETICA
  IMPUESTOS
  TRAMITE
  COMISION
  PARQUEADERO
  PUBLICIDAD
  COMBUSTIBLE
  OTRO
}

enum PayableStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PayableType {
  RECEIVABLE
  PAYABLE
}

enum Role {
  ADMIN
  VIEWER
}

enum ThirdPartyType {
  SUPPLIER
  CLIENT
  PARTNER
}

enum TransactionCategory {
  VEHICLE_SALE
  VEHICLE_SALE_PARTIAL
  CAPITAL_CONTRIBUTION
  OTHER_INCOME
  VEHICLE_PURCHASE
  VEHICLE_EXPENSE
  OPERATING_EXPENSE
  OTHER_EXPENSE
  TRANSFER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER_IN
  TRANSFER_OUT
}

enum VehicleStage {
  NEGOCIANDO
  COMPRADO
  ALISTAMIENTO
  PUBLICADO
  DISPONIBLE
  VENDIDO
}
