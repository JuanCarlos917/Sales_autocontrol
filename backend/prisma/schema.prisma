// ═══════════════════════════════════════════════════════════════
// AutoControl — Database Schema (Prisma)
// Fuente de verdad para todas las tablas y relaciones
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════
// USUARIOS Y AUTENTICACIÓN
// ══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  pin           String?
  name          String?
  role          Role      @default(ADMIN)
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vehicles      Vehicle[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

enum Role {
  ADMIN
  VIEWER
}

// ══════════════════════════════════════════════════════════════
// VEHÍCULOS
// ══════════════════════════════════════════════════════════════

model Vehicle {
  id                    String        @id @default(cuid())
  plate                 String
  brand                 String?
  model                 String?
  year                  Int?
  color                 String?
  km                    Int?
  stage                 VehicleStage  @default(NEGOCIANDO)

  purchasePrice         Decimal?      @db.Decimal(15, 2)
  listedPrice           Decimal?      @db.Decimal(15, 2)
  salePrice             Decimal?      @db.Decimal(15, 2)
  participation         Decimal       @default(1.0) @db.Decimal(5, 4)

  purchaseDate          DateTime?
  saleDate              DateTime?

  receivedVehicle       Boolean       @default(false)
  receivedVehiclePlate  String?
  receivedVehicleValue  Decimal?      @db.Decimal(15, 2)

  publishedPortals      String[]      @default([])

  notes                 String?
  userId                String
  user                  User          @relation(fields: [userId], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  expenses              Expense[]
  documents             Document[]
  payables              Payable[]

  @@index([userId, stage])
  @@index([plate])
  @@map("vehicles")
}

enum VehicleStage {
  NEGOCIANDO
  COMPRADO
  ALISTAMIENTO
  PUBLICADO
  DISPONIBLE
  VENDIDO
}

// ══════════════════════════════════════════════════════════════
// GASTOS
// ══════════════════════════════════════════════════════════════

model Expense {
  id          String          @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(15, 2)
  description String?
  notes       String?
  date        DateTime?
  paid        Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  payable     Payable?

  @@index([vehicleId])
  @@index([category])
  @@map("expenses")
}

enum ExpenseCategory {
  MECANICA
  ESTETICA
  IMPUESTOS
  TRAMITE
  COMISION
  PARQUEADERO
  PUBLICIDAD
  COMBUSTIBLE
  OTRO
}

// ══════════════════════════════════════════════════════════════
// DOCUMENTOS
// ══════════════════════════════════════════════════════════════

model Document {
  id          String       @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type        DocumentType
  filename    String
  filepath    String
  mimetype    String?
  size        Int?
  notes       String?
  createdAt   DateTime     @default(now())

  @@index([vehicleId])
  @@map("documents")
}

enum DocumentType {
  TARJETA_PROPIEDAD
  SOAT
  TECNOMECANICA
  PERITAJE
  CERTIFICADO_TRADICION
  CONTRATO
  FOTO_VEHICULO
  OTRO
}

// ══════════════════════════════════════════════════════════════
// CONFIGURACIÓN
// ══════════════════════════════════════════════════════════════

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - CUENTAS
// ══════════════════════════════════════════════════════════════

model Account {
  id             String      @id @default(cuid())
  name           String
  type           AccountType
  bank           String?
  accountNumber  String?
  initialBalance Decimal     @default(0) @db.Decimal(15, 2)
  currentBalance Decimal     @default(0) @db.Decimal(15, 2)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transactions    Transaction[]
  transfersFrom   Transfer[]    @relation("TransferFrom")
  transfersTo     Transfer[]    @relation("TransferTo")
  cashCounts      CashCount[]

  @@map("accounts")
}

enum AccountType {
  CASH
  BANK
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - TERCEROS
// ══════════════════════════════════════════════════════════════

model ThirdParty {
  id        String         @id @default(cuid())
  name      String
  type      ThirdPartyType
  document  String?
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  transactions Transaction[]
  payables     Payable[]

  @@map("third_parties")
}

enum ThirdPartyType {
  CLIENT
  SUPPLIER
  BOTH
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - TRANSACCIONES
// ══════════════════════════════════════════════════════════════

model Transaction {
  id           String              @id @default(cuid())
  accountId    String
  account      Account             @relation(fields: [accountId], references: [id])
  type         TransactionType
  category     TransactionCategory
  amount       Decimal             @db.Decimal(15, 2)
  description  String?
  reference    String?
  date         DateTime            @default(now())
  vehicleId    String?
  thirdPartyId String?
  thirdParty   ThirdParty?         @relation(fields: [thirdPartyId], references: [id])
  transferId   String?
  transfer     Transfer?           @relation(fields: [transferId], references: [id])
  expenseId    String?             @unique
  createdBy    String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  payablePayment PayablePayment?

  @@index([accountId])
  @@index([vehicleId])
  @@index([thirdPartyId])
  @@index([date])
  @@index([type, category])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER_IN
  TRANSFER_OUT
}

enum TransactionCategory {
  VEHICLE_PURCHASE
  VEHICLE_SALE
  VEHICLE_SALE_PARTIAL
  VEHICLE_EXPENSE
  FIXED_EXPENSE
  OPERATING_EXPENSE
  COMMISSION
  CAPITAL_CONTRIBUTION
  OTHER_INCOME
  OTHER_EXPENSE
  TRANSFER
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - TRANSFERENCIAS
// ══════════════════════════════════════════════════════════════

model Transfer {
  id            String   @id @default(cuid())
  fromAccountId String
  fromAccount   Account  @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccountId   String
  toAccount     Account  @relation("TransferTo", fields: [toAccountId], references: [id])
  amount        Decimal  @db.Decimal(15, 2)
  description   String?
  date          DateTime @default(now())
  createdBy     String
  createdAt     DateTime @default(now())

  transactions Transaction[]

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([date])
  @@map("transfers")
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - ARQUEOS
// ══════════════════════════════════════════════════════════════

model CashCount {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id])
  expectedBalance Decimal  @db.Decimal(15, 2)
  countedBalance  Decimal  @db.Decimal(15, 2)
  difference      Decimal  @db.Decimal(15, 2)
  notes           String?
  date            DateTime @default(now())
  createdBy       String
  createdAt       DateTime @default(now())

  @@index([accountId])
  @@index([date])
  @@map("cash_counts")
}

// ══════════════════════════════════════════════════════════════
// TESORERÍA - CUENTAS POR COBRAR / PAGAR (CxC / CxP)
// ══════════════════════════════════════════════════════════════

model Payable {
  id           String        @id @default(cuid())
  type         PayableType
  status       PayableStatus @default(PENDING)
  totalAmount  Decimal       @db.Decimal(15, 2)
  paidAmount   Decimal       @default(0) @db.Decimal(15, 2)
  dueDate      DateTime?
  description  String?
  vehicleId    String?
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id])
  expenseId    String?       @unique
  expense      Expense?      @relation(fields: [expenseId], references: [id])
  thirdPartyId String?
  thirdParty   ThirdParty?   @relation(fields: [thirdPartyId], references: [id])
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  payments PayablePayment[]

  @@index([vehicleId])
  @@index([thirdPartyId])
  @@index([type, status])
  @@index([dueDate])
  @@map("payables")
}

model PayablePayment {
  id            String      @id @default(cuid())
  payableId     String
  payable       Payable     @relation(fields: [payableId], references: [id], onDelete: Cascade)
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  amount        Decimal     @db.Decimal(15, 2)
  createdAt     DateTime    @default(now())

  @@index([payableId])
  @@map("payable_payments")
}

enum PayableType {
  RECEIVABLE
  PAYABLE
}

enum PayableStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}
